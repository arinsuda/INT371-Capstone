APP_NAME=CAPSTONE-API
APP_ENV=development
APP_DEBUG=false
PORT=8080

DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=changSure
DB_PASSWORD=changSure@sit.65
DB_NAME=changsurev1
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300
DB_SSLMODE=disable

SEED_ON_BOOT=true

JWT_SECRET=changsureSecretKeysit65
JWT_ACCESS_TOKEN_TTL=24
JWT_REFRESH_TOKEN_TTL=168

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_BUCKET=changSure

PRESIGN_UPLOAD_TTL=900
PRESIGN_DOWNLOAD_TTL=600
MAX_FILE_MB=50
ALLOW_MIME=application/pdf,image/jpeg,image/png
ALLOW_DOC_TYPES=id_card,certificate,license,portfolio,insurance
ENABLE_VIRUS_SCAN=true

TESSDATA_PREFIX=/opt/homebrew/share/tessdata
OCR_LANGUAGE=eng
OCR_PSM=7
OCR_OEM=1
OCR_CONFIDENCE_MIN=0.20
OCR_CONFIDENCE_WARNING=70

ENABLE_PREPROCESSING=true
PREPROCESSING_METHOD=native

OCR_MAX_FILE_SIZE=10485760
OCR_MIN_IMAGE_WIDTH=300
OCR_MIN_IMAGE_HEIGHT=200
OCR_ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff

OCR_ID_CROP_X=0.20
OCR_ID_CROP_Y=0.14
OCR_ID_CROP_W=0.60
OCR_ID_CROP_H=0.10

OCR_UPSCALE_FACTOR=3.0

OCR_STRATEGY_AGGRESSIVE=true
OCR_STRATEGY_FULL=true
OCR_STRATEGY_CROPPED=true
OCR_STRATEGY_NORMALIZED=true
OCR_STOP_ON_SUCCESS=true
OCR_MIN_CONFIDENCE_STOP=0.75

OCR_CONCURRENT=true
OCR_MAX_CONCURRENCY=3
OCR_ENABLE_CACHE=true
OCR_ENABLE_METRICS=true
OCR_DEBUG=true
OCR_SAVE_DEBUG_IMAGES=false