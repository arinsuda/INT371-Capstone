# ========================================
# Application Configuration
# ========================================
APP_NAME=CAPSTONE-API
APP_ENV=development
APP_DEBUG=true
PORT=8080

# ========================================
# Database Configuration
# ========================================
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=changSure
DB_PASSWORD=changSure@sit.65
DB_NAME=changsurev1
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300

# ========================================
# JWT Configuration
# ========================================
JWT_SECRET=changsureSecretKeysit65
JWT_ACCESS_TOKEN_TTL=24
JWT_REFRESH_TOKEN_TTL=168

# ========================================
# CORS Configuration
# ========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# Redis Configuration
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========================================
# MinIO Configuration
# ========================================
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=
MINIO_BUCKET=oneplatform

# ========================================
# File Upload Configuration
# ========================================
PRESIGN_UPLOAD_TTL=900       # วินาที (15 นาที)
PRESIGN_DOWNLOAD_TTL=600     # วินาที (10 นาที)
MAX_FILE_MB=50
ALLOW_MIME=application/pdf,image/jpeg,image/png
ALLOW_DOC_TYPES=id_card,certificate,license,portfolio,insurance
ENABLE_VIRUS_SCAN=false

# ========================================
# OCR Configuration
# ========================================
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe
TESSDATA_PREFIX=C:/Program Files/Tesseract-OCR/tessdata

OCR_LANGUAGE=eng

# Page Segmentation Mode
OCR_PSM=7

# OCR Engine Mode
OCR_OEM=3

# Confidence thresholds (0-100)
OCR_CONFIDENCE_MIN=0.20
OCR_CONFIDENCE_WARNING=70

# Image preprocessing
ENABLE_PREPROCESSING=true
PREPROCESSING_METHOD=native

# OCR-specific file limits (for image uploads)
OCR_MAX_FILE_SIZE=10485760
OCR_MIN_IMAGE_WIDTH=300
OCR_MIN_IMAGE_HEIGHT=200
OCR_ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff

OCR_ID_CROP_X=0.25      # เริ่มที่ 25% จากซ้าย (หลัง barcode)
OCR_ID_CROP_Y=0.15      # เริ่มที่ 15% จากบน
OCR_ID_CROP_W=0.50      # กว้าง 50%
OCR_ID_CROP_H=0.08 

OCR_UPSCALE_FACTOR=3.0

# ========================================
# OCR Strategy Configuration
# ========================================
OCR_STRATEGY_AGGRESSIVE=true
OCR_STRATEGY_FULL=true
OCR_STRATEGY_CROPPED=true
OCR_STRATEGY_NORMALIZED=true
OCR_STOP_ON_SUCCESS=true
OCR_MIN_CONFIDENCE_STOP=0.80

# Performance
OCR_CONCURRENT=true
OCR_MAX_CONCURRENCY=3
OCR_ENABLE_CACHE=true
OCR_ENABLE_METRICS=true

OCR_DEBUG=true
OCR_SAVE_DEBUG_IMAGES=true

TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe
TESSDATA_PREFIX=C:/Program Files/Tesseract-OCR/tessdata