# ============================================================
# APPLICATION
# ============================================================
APP_NAME=CAPSTONE-API
APP_ENV=development
APP_DEBUG=false
PORT=8080
SEED_ON_BOOT=false
ENABLE_DOCS=false

# ============================================================
# DATABASE (MySQL)
# ============================================================
DB_DRIVER=mysql
DB_HOST=database
DB_PORT=3306
DB_USERNAME=changsure_user
DB_PASSWORD=changsure_password
DB_NAME=changsure_v2
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=300
DB_SSLMODE=disable

# ============================================================
# DATABASE DOCKER (MySQL Container)
# ============================================================
MYSQL_VERSION=8.0
MYSQL_ROOT_PASSWORD=mysql
MYSQL_DATABASE=changsure
MYSQL_USER=changsure_user
MYSQL_PASSWORD=changsure_password

# ============================================================
# REDIS
# ============================================================
REDIS_VERSION=7-alpine
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=none
REDIS_DB=1

# ============================================================
# OBJECT STORAGE (MinIO)
# ============================================================
MINIO_VERSION=latest
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=bscit.sit.kmutt.ac.th
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=changsure-dev
MINIO_USE_SSL=true
MINIO_REGION=us-east-1

# ============================================================
# FILE UPLOAD
# ============================================================
MAX_FILE_MB=50
ALLOW_MIME=application/pdf,image/jpeg,image/png
ALLOW_DOC_TYPES=id_card,certificate,license,portfolio,insurance
PRESIGN_UPLOAD_TTL=900
PRESIGN_DOWNLOAD_TTL=600
ENABLE_VIRUS_SCAN=true

# ============================================================
# OCR SERVICE
# ============================================================
OCR_BASE_URL=http://ocr:8000
OCR_LANGUAGES=["th","en"]
OCR_USE_GPU=false
OCR_WORKERS=1
OCR_TIMEOUT_SECONDS=120
OCR_MAX_CONCURRENT=2
OCR_POLL_INTERVAL_SECONDS=5
OCR_MANUAL_THRESHOLD_MINUTES=30

# ============================================================
# OCR IMAGE VALIDATION
# ============================================================
MAX_FILE_SIZE_MB=10.0
MIN_IMAGE_WIDTH=300
MIN_IMAGE_HEIGHT=200
MAX_IMAGE_WIDTH=8000
MAX_IMAGE_HEIGHT=8000
MIN_CONFIDENCE_THRESHOLD=0.3

# ============================================================
# OCR PREPROCESSING
# ============================================================
ENABLE_PREPROCESSING=true
ENABLE_DESKEW=true
ENABLE_DENOISE=false
TARGET_DPI=300

# ============================================================
# AUTHENTICATION (JWT)
# ============================================================
JWT_SECRET=prod-changsure-secret-key-2025
JWT_ACCESS_TOKEN_TTL=86400
JWT_REFRESH_TOKEN_TTL=604800

# ============================================================
# CORS
# ============================================================
ALLOWED_ORIGINS=https://cp25ssa1.sit.kmutt.ac.th,https://your-app-domain.com

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60

# ============================================================
# PAYMENT GATEWAY (Omise)
# ============================================================
OMISE_ENV=test
OMISE_PUBLIC_KEY=pkey_test_66mtsehgd6tauz5v41g
OMISE_SECRET_KEY=skey_test_66mtsehyeh5nz2f1a1u
OMISE_CURRENCY=thb
OMISE_TIMEOUT_SECONDS=30
OMISE_QR_EXPIRY_MINUTES=15
