# ========================================
# APPLICATION CONFIGURATION
# ========================================
APP_NAME=CAPSTONE-API
APP_ENV=development
APP_DEBUG=true
PORT=8080

# ========================================
# DOCKER SERVICE CREDENTIALS
# ========================================
# MySQL Root Password (for Docker container)
MYSQL_ROOT_PASSWORD=mysql
MYSQL_DATABASE=changsure
MYSQL_USER=changsure_user
MYSQL_PASSWORD=changsure_password
MYSQL_VERSION=8.0

# MinIO Admin Credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_VERSION=latest

# Redis Version
REDIS_VERSION=7-alpine

# ========================================
# DATABASE CONNECTION
# ========================================
DB_DRIVER=mysql
DB_HOST=database
DB_PORT=3306
DB_USERNAME=changsure_user
DB_PASSWORD=changsure_password
DB_NAME=changsure
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300
DB_SSLMODE=disable

# ========================================
# DATABASE SEED
# ========================================
SEED_ON_BOOT=true

# ========================================
# JWT AUTHENTICATION
# ========================================
JWT_SECRET=dev-changsure-secret-key-cp25ssa1-sit-kmutt-ac-th
JWT_ACCESS_TOKEN_TTL=1440
JWT_REFRESH_TOKEN_TTL=10080

# ========================================
# CORS CONFIGURATION
# ========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# REDIS CONFIGURATION
# ========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=none
REDIS_DB=0

# ========================================
# MINIO (S3-Compatible Storage)
# ========================================
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_URL=http://cp25ssa1.sit.kmutt.ac.th:9010
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_BUCKET=changsure-dev

# File Upload Settings
PRESIGN_UPLOAD_TTL=900
PRESIGN_DOWNLOAD_TTL=600
MAX_FILE_MB=50
ALLOW_MIME=application/pdf,image/jpeg,image/png
ALLOW_DOC_TYPES=id_card,certificate,license,portfolio,insurance
ENABLE_VIRUS_SCAN=true

# ========================================
# OCR SERVICE (PaddleOCR Microservice)
# ========================================
OCR_BASE_URL=http://ocr:8000

# ========================================
# OCR PIPELINE CONFIGURATION
# ========================================
# Tesseract Settings
TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata
OCR_LANGUAGE=eng+tha
OCR_PSM=7
OCR_OEM=1
OCR_CONFIDENCE_MIN=0.20
OCR_CONFIDENCE_WARNING=70

# Preprocessing
ENABLE_PREPROCESSING=true
PREPROCESSING_METHOD=native

# Image Requirements
OCR_MAX_FILE_SIZE=10485760
OCR_MIN_IMAGE_WIDTH=300
OCR_MIN_IMAGE_HEIGHT=200
OCR_ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff

# ID Card Cropping (X, Y, Width, Height as percentages)
OCR_ID_CROP_X=0.20
OCR_ID_CROP_Y=0.14
OCR_ID_CROP_W=0.60
OCR_ID_CROP_H=0.10

# Image Enhancement
OCR_UPSCALE_FACTOR=3.0

# OCR Strategy Flags
OCR_STRATEGY_AGGRESSIVE=true
OCR_STRATEGY_FULL=true
OCR_STRATEGY_CROPPED=true
OCR_STRATEGY_NORMALIZED=true
OCR_STOP_ON_SUCCESS=true
OCR_MIN_CONFIDENCE_STOP=0.75

# Performance & Debugging
OCR_CONCURRENT=true
OCR_MAX_CONCURRENCY=3
OCR_ENABLE_CACHE=true
OCR_ENABLE_METRICS=true
OCR_DEBUG=false
OCR_SAVE_DEBUG_IMAGES=false