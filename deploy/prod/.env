########################################
#            APPLICATION
########################################
APP_NAME=CAPSTONE-API
APP_ENV=production
APP_DEBUG=false
PORT=8080

########################################
#            MYSQL DATABASE
########################################
MYSQL_ROOT_PASSWORD=mysql
MYSQL_DATABASE=changsure
MYSQL_USER=changsure_user
MYSQL_PASSWORD=changsure_password

DB_DRIVER=mysql
DB_HOST=database
DB_PORT=3306
DB_USERNAME=changsure_user
DB_PASSWORD=changsure_password
DB_NAME=changsure
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300
DB_SSLMODE=disable

########################################
#                SEED
########################################
SEED_ON_BOOT=true

########################################
#                JWT
########################################
JWT_SECRET=prod-changsure-secret-key-cp25ssa1-sit-kmutt-ac-th
JWT_ACCESS_TOKEN_TTL=1440
JWT_REFRESH_TOKEN_TTL=10080

########################################
#                CORS
########################################
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8081

########################################
#                REDIS
########################################
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=none
REDIS_DB=0

########################################
#                MINIO
########################################
# Endpoint inside Docker network
MINIO_ENDPOINT=minio:9000

# MinIO v2023+ required format (NO MORE MINIO_ACCESS_KEY)
MINIO_ROOT_USER=changsureadmin
MINIO_ROOT_PASSWORD=supersecret123

# For backend compatibility (core-service might still read these)
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}

MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_BUCKET=changsure-prod

# Presigned URL TTL
PRESIGN_UPLOAD_TTL=900
PRESIGN_DOWNLOAD_TTL=600

# Upload config
MAX_FILE_MB=50
ALLOW_MIME=application/pdf,image/jpeg,image/png
ALLOW_DOC_TYPES=id_card,certificate,license,portfolio,insurance
ENABLE_VIRUS_SCAN=true

########################################
#              OCR SERVICE
########################################
OCR_BASE_URL=http://ocr:8000

# OCR pipeline
TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata
OCR_LANGUAGE=eng+tha
OCR_PSM=7
OCR_OEM=1
OCR_CONFIDENCE_MIN=0.20
OCR_CONFIDENCE_WARNING=70

ENABLE_PREPROCESSING=true
PREPROCESSING_METHOD=native

OCR_MAX_FILE_SIZE=10485760
OCR_MIN_IMAGE_WIDTH=300
OCR_MIN_IMAGE_HEIGHT=200
OCR_ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff

OCR_ID_CROP_X=0.20
OCR_ID_CROP_Y=0.14
OCR_ID_CROP_W=0.60
OCR_ID_CROP_H=0.10

OCR_UPSCALE_FACTOR=3.0

OCR_STRATEGY_AGGRESSIVE=true
OCR_STRATEGY_FULL=true
OCR_STRATEGY_CROPPED=true
OCR_STRATEGY_NORMALIZED=true
OCR_STOP_ON_SUCCESS=true
OCR_MIN_CONFIDENCE_STOP=0.75

OCR_CONCURRENT=true
OCR_MAX_CONCURRENCY=3
OCR_ENABLE_CACHE=true
OCR_ENABLE_METRICS=true
OCR_DEBUG=false
OCR_SAVE_DEBUG_IMAGES=false
